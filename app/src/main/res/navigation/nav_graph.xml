<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/tableListFragment">

    <fragment
        android:id="@+id/tableListFragment"
        android:name="com.cfg.android.ui.tables.TableListFragment"
        android:label="Tables">
        <action
            android:id="@+id/action_tableList_to_order"
            app:destination="@id/orderFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/orderFragment"
        android:name="com.cfg.android.ui.order.OrderFragment"
        android:label="Commande">
        <argument
            android:name="tableId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="tableNumber"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="tableLabel"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="orderId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_order_to_cart"
            app:destination="@id/cartFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.cfg.android.ui.order.CartFragment"
        android:label="Panier">
        <action
            android:id="@+id/action_cart_to_payment"
            app:destination="@id/paymentFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.cfg.android.ui.payment.PaymentFragment"
        android:label="Paiement">
        <argument
            android:name="orderId"
            app:argType="string" />
        <argument
            android:name="totalAmount"
            app:argType="float"
            android:defaultValue="0" />
    </fragment>

</navigation>
